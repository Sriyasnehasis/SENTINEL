rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if the user is the specific admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin123@gmail.com';
    }

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Incidents: Everyone can read, only admin can create/update/delete
    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Sessions: Everyone can read, only admin can update
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Staff: Only admin can manage staff records
    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
